---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Navigation from "../components/Navigation.astro";
import { SITE_AUTHOR, SITE_EMAIL } from "../consts";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage, category } =
	Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={`${title} | ${SITE_AUTHOR}`} description={description} />
	</head>
	<body>
		<Navigation />
		
		<main class="pt-32 pb-20 px-8 max-w-3xl mx-auto">
			<article>
				<!-- Article Header -->
				<header class="mb-16">
					<div class="flex items-center gap-4 text-[10px] font-bold tracking-[0.2em] uppercase text-on-surface-variant mb-6">
						<span class="text-primary">{category || 'Development'}</span>
						<span class="w-1.5 h-[1px] bg-primary/40"></span>
						<time datetime={pubDate.toISOString()}>
							<FormattedDate date={pubDate} />
						</time>
						{updatedDate && (
							<>
								<span class="w-1.5 h-[1px] bg-primary/40"></span>
								<span class="text-on-surface-variant/60">Updated <FormattedDate date={updatedDate} /></span>
							</>
						)}
					</div>
					
					<h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-on-surface leading-tight font-headline uppercase mb-8">
						{title}
					</h1>
					
					<p class="text-lg text-on-surface-variant leading-relaxed">
						{description}
					</p>
				</header>
				
				<!-- Hero Image -->
				{heroImage && (
					<div class="mb-16 border border-outline p-2 bg-surface">
						<img
							src={heroImage}
							alt={title}
							class="w-full h-auto"
						/>
					</div>
				)}
				
				<!-- Article Content -->
				<div class="prose prose-invert max-w-none
					[&>h2]:text-2xl [&>h2]:font-bold [&>h2]:font-headline [&>h2]:tracking-tighter [&>h2]:uppercase [&>h2]:text-on-surface [&>h2]:mt-16 [&>h2]:mb-8
					[&>h3]:text-xl [&>h3]:font-bold [&>h3]:font-headline [&>h3]:tracking-tight [&>h3]:uppercase [&>h3]:text-on-surface [&>h3]:mt-12 [&>h3]:mb-6
					[&>p]:text-on-surface-variant [&>p]:leading-relaxed [&>p]:mb-8
					[&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-8 [&>ul]:text-on-surface-variant
					[&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:mb-8 [&>ol]:text-on-surface-variant
					[&>li]:mb-2
					[&>a]:text-primary [&>a]:underline [&>a]:underline-offset-4 [&>a]:hover:text-primary/80
					[&>blockquote]:border-l-4 [&>blockquote]:border-primary [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:text-on-surface-variant/80 [&>blockquote]:my-8
					[&>code]:bg-surface [&>code]:px-2 [&>code]:py-1 [&>code]:text-primary [&>code]:text-sm
					[&>pre]:bg-surface [&>pre]:border [&>pre]:border-outline [&>pre]:p-6 [&>pre]:overflow-x-auto [&>pre]:mb-8
					[&>pre>code]:bg-transparent [&>pre>code]:p-0
				">
					<slot />
				</div>
				
				<!-- Article Footer -->
				<footer class="mt-24 pt-12 border-t border-outline">
					<div class="flex flex-col md:flex-row justify-between items-start gap-8">
						<div>
							<h3 class="text-xs font-headline font-bold text-primary uppercase tracking-[0.2em] mb-4">Written By</h3>
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-primary/20 flex items-center justify-center">
									<span class="text-primary font-bold text-lg">{SITE_AUTHOR.charAt(0)}</span>
								</div>
								<div>
									<p class="font-bold text-on-surface">{SITE_AUTHOR}</p>
									<p class="text-sm text-on-surface-variant">Full-Stack Developer</p>
								</div>
							</div>
						</div>
						<div>
							<h3 class="text-xs font-headline font-bold text-primary uppercase tracking-[0.2em] mb-4">Get in Touch</h3>
							<a href={`mailto:${SITE_EMAIL}`} class="text-on-surface-variant hover:text-primary transition-colors text-sm">
								{SITE_EMAIL}
							</a>
						</div>
					</div>
				</footer>
			</article>
		</main>
		
		<Footer />
	</body>
</html>
