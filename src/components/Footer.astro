---
import { SITE_TITLE, SOCIAL_LINKS } from "../consts";
---

<footer class="w-full bg-surface border-t border-outline/20">
	<div class="flex flex-col gap-8 p-8 md:p-12 w-full max-w-7xl mx-auto">
		<div class="flex flex-col md:flex-row justify-between items-start gap-8">
			<div>
				<div class="font-headline text-lg font-bold tracking-tighter uppercase text-on-background mb-2">
					{SITE_TITLE}
				</div>
				<div class="text-on-background/40 text-sm">
					© {new Date().getFullYear()} {SITE_TITLE.toUpperCase()}. ALL RIGHTS RESERVED.
				</div>
			</div>
			
			<div class="flex flex-wrap gap-6">
				{SOCIAL_LINKS.map((link) => (
					<a
						href={link.href}
						target="_blank"
						rel="noopener noreferrer"
						class="text-on-background/60 hover:text-primary text-sm uppercase tracking-widest transition-colors"
					>
						{link.label}
					</a>
				))}
			</div>
		</div>
	</div>
</footer>
