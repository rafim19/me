---
import { NAV_LINKS, SITE_EMAIL, SITE_TITLE } from "../consts";

const currentPath = Astro.url.pathname;
---

<nav class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 glass-nav rounded-full md:top-4 md:bottom-auto shadow-xl outline-[0.5px] outline-background-variant dark:outline-background-variant/30">
	<div class="flex items-center gap-2 px-3 py-2 md:hidden">
		<a href="/" class="decoration-0 hover:scale-105 transition-all! lowercase">
			<span class="font-mono font-bold text-sm">[<span class="font-bold">rafidev</span>];</span>
		</a>
		
		<button
			id="mobile-menu-btn"
			class="ml-auto p-2 text-on-background hover:text-primary hover:bg-primary/10 rounded-full transition-colors"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</div>

	<div class="hidden md:flex items-center gap-2 px-3 py-2">
		<a href="/" class="decoration-0 hover:scale-105 transition-all! mx-2 lowercase">
			<span class="font-mono font-bold text-sm">[<span class="font-bold">rafidev</span>];</span>
		</a>

		{NAV_LINKS.map((link) => (
			<a
				href={link.href}
				class:list={[
					'font-headline tracking-tighter uppercase text-xs transition-colors duration-200 px-4 py-2 rounded-full',
					(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)))
						? 'bg-primary text-background'
						: 'text-on-background hover:bg-primary/10 hover:text-primary'
				]}
			>
				{link.label}
			</a>
		))}
		
		<div class="w-px h-6 bg-outline/20"></div>
		
		<button
			id="theme-toggle"
			class="p-2 text-on-background hover:text-primary hover:bg-primary/10 rounded-full transition-colors"
			aria-label="Toggle theme"
		>
			<svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
			</svg>
			<svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
			</svg>
		</button>
		
		<a
			href={`mailto:${SITE_EMAIL}`}
			class="bg-primary text-background px-5 py-2 text-xs font-bold uppercase tracking-widest hover:opacity-90 transition-all rounded-full"
		>
			Contact
		</a>
	</div>
</nav>

<!-- Mobile Menu Overlay -->
<div
	id="mobile-menu"
	class="fixed inset-0 z-40 bg-background/95 backdrop-blur-lg md:hidden hidden flex-col items-center justify-center gap-6"
>
	<a href="/" class="font-mono font-bold text-2xl lowercase mb-8">
		[<span class="font-bold">rafidev</span>];
	</a>

	{NAV_LINKS.map((link) => (
		<a
			href={link.href}
			class:list={[
				'font-headline tracking-tighter uppercase text-2xl transition-colors duration-200 px-6 py-3 rounded-full',
				(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)))
					? 'bg-primary text-background'
					: 'text-on-background hover:bg-primary/10 hover:text-primary'
			]}
		>
			{link.label}
		</a>
	))}
	
	<div class="w-px h-8 bg-outline/20 my-2"></div>
	
	<button
		id="theme-toggle-mobile"
		class="p-3 text-on-background hover:text-primary hover:bg-primary/10 rounded-full transition-colors"
		aria-label="Toggle theme"
	>
		<svg id="sun-icon-mobile" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
		</svg>
		<svg id="moon-icon-mobile" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
		</svg>
	</button>
	
	<a
		href={`mailto:${SITE_EMAIL}`}
		class="bg-primary text-background px-8 py-4 text-sm font-bold uppercase tracking-widest hover:opacity-90 transition-all rounded-full mt-4"
	>
		Contact
	</a>
</div>

<script>
	const themeToggle = document.getElementById('theme-toggle');
	const themeToggleMobile = document.getElementById('theme-toggle-mobile');
	const sunIcon = document.getElementById('sun-icon');
	const moonIcon = document.getElementById('moon-icon');
	const sunIconMobile = document.getElementById('sun-icon-mobile');
	const moonIconMobile = document.getElementById('moon-icon-mobile');
	const mobileMenuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');
	
	function updateIcons(isDark: boolean) {
		const updatePair = (sun: SVGElement | null, moon: SVGElement | null) => {
			if (isDark) {
				sun?.classList.remove('hidden');
				moon?.classList.add('hidden');
			} else {
				sun?.classList.add('hidden');
				moon?.classList.remove('hidden');
			}
		};
		updatePair(sunIcon, moonIcon);
		updatePair(sunIconMobile, moonIconMobile);
	}
	
	function toggleTheme() {
		const isCurrentlyDark = document.documentElement.classList.toggle('dark');
		localStorage.setItem('theme', isCurrentlyDark ? 'dark' : 'light');
		updateIcons(isCurrentlyDark);
	}
	
	const isDark = document.documentElement.classList.contains('dark');
	updateIcons(isDark);
	
	themeToggle?.addEventListener('click', toggleTheme);
	themeToggleMobile?.addEventListener('click', toggleTheme);
	
	mobileMenuBtn?.addEventListener('click', () => {
		const isOpen = !mobileMenu?.classList.contains('hidden');
		
		if (isOpen) {
			mobileMenu?.classList.add('hidden');
			mobileMenu?.classList.remove('flex');
			mobileMenuBtn?.setAttribute('aria-expanded', 'false');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		} else {
			mobileMenu?.classList.remove('hidden');
			mobileMenu?.classList.add('flex');
			mobileMenuBtn?.setAttribute('aria-expanded', 'true');
			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		}
	});
	
	mobileMenu?.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => {
			mobileMenu?.classList.add('hidden');
			mobileMenu?.classList.remove('flex');
			mobileMenuBtn?.setAttribute('aria-expanded', 'false');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		});
	});
</script>
